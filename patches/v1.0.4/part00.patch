+def extract_all_eight_digit_ids(value: Any) -> list[str]:
+    """Return every standalone 8-digit number contained in one imported cell."""
+    if isinstance(value, bool) or value is None:
+        return []
+    if isinstance(value, int):
+        raw = str(value)
+    elif isinstance(value, float) and value.is_integer():
+        raw = str(int(value))
+    else:
+        raw = cell_text(value)
+        # Excel and CSV exports sometimes render whole numbers with a trailing .0.
+        if re.fullmatch(r"\d{8}\.0+", raw):
+            raw = raw.split(".", 1)[0]
+    return re.findall(r"(?<!\d)(\d{8})(?!\d)", raw)
+
