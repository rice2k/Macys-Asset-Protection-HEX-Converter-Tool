+    def close_results_popout(self) -> None:
+        if self.results_popout is not None:
+            try:
+                self.results_popout.destroy()
+            except tk.TclError:
+                pass
+        self.results_popout = None
+        self.results_popout_tree = None
+        self.results_popout_lookup = {}
+
+    def refresh_results_popout(self) -> None:
+        tree = self.results_popout_tree
+        if tree is None or not tree.winfo_exists():
+            return
+        for item in tree.get_children():
+            tree.delete(item)
+        self.results_popout_lookup = {}
+        search_text = getattr(self, "results_popout_search_var", tk.StringVar(value="")).get().strip().lower()
+        status_filter = getattr(self, "results_popout_status_var", tk.StringVar(value="All")).get().lower()
+        combined: list[ConvertedRow | InvalidRow] = list(self.results) + list(self.invalid)
+        combined.sort(key=lambda row: row.line)
+        shown = 0
+        for row in combined:
+            if isinstance(row, ConvertedRow):
+                status = row.status
+                values = (row.line, row.hex_value, row.facility, row.card, row.status, row.notes)
+                tag = "warning" if row.status == "Warning" else "valid"
+            else:
+                status = "Invalid"
+                values = (row.line, row.raw, "", "", "Invalid", row.reason)
+                tag = "invalid"
+            searchable = " ".join(str(value) for value in values).lower()
+            if search_text and search_text not in searchable:
+                continue
+            if status_filter != "all" and status.lower() != status_filter:
+                continue
+            item_id = tree.insert("", "end", values=values, tags=(tag,))
+            self.results_popout_lookup[item_id] = row
+            shown += 1
+        if hasattr(self, "results_popout_count_var"):
+            self.results_popout_count_var.set(f"Showing {shown} of {len(combined)} row(s)")
+
+    def copy_popout_selected(self, mode: str) -> None:
+        tree = self.results_popout_tree
+        if tree is None:
+            return
+        selected = tree.selection()
+        if not selected:
+            messagebox.showinfo("Select a result", "Select a valid result row first.", parent=self.results_popout)
+            return
+        row = self.results_popout_lookup.get(selected[0])
+        if row is None or isinstance(row, InvalidRow):
+            messagebox.showinfo("Invalid row", "The selected row does not contain a valid FC/CN result.", parent=self.results_popout)
+            return
+        values = {
+            "hex": row.hex_value,
+            "fc": str(row.facility),
+            "cn": str(row.card),
+            "pair": f"{row.facility},{row.card}",
+        }
+        self.clipboard_clear()
+        self.clipboard_append(values.get(mode, values["pair"]))
+        self.set_status("Selected result copied from the full results window.")
+
